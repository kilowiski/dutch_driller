# Dutch Driller environment variables
# Copy this to .env and fill in your values

# DeepSeek API key — needed for Explain button + content generator
# Get one at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Flask session secret — any random string
SECRET_KEY=some-random-string-change-this

# Admin page password — access /admin?pw=this_password
ADMIN_PASSWORD=some-random-string-change-this
